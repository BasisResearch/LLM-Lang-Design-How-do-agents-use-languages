cabal-version:      2.4
name:               todo-app
version:            0.1.0.0
synopsis:           Todo App REST API
build-type:         Simple

executable todo-app
  main-is:          Main.hs
  hs-source-dirs:   src
  build-depends:    base >= 4.14 && < 5
                  , scotty
                  , aeson
                  , text
                  , bytestring
                  , containers
                  , time
                  , uuid
                  , cryptonite
                  , http-types
                  , wai
                  , random
  default-language: Haskell2010
  ghc-options:      -Wall -O2
