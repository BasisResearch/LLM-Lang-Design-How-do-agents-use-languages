cabal-version:       3.4
name:                todo-hs
version:             0.1.0.0
license:             BSD-3-Clause
build-type:          Simple

executable todo-hs
  main-is:             Main.hs
  hs-source-dirs:      app
  default-language:    Haskell2010
  ghc-options:         -Wall -O2 -threaded -rtsopts -with-rtsopts=-N
  build-depends:       base >=4.14 && <5,
                       aeson,
                       text,
                       bytestring,
                       containers,
                       http-types,
                       wai,
                       warp,
                       scotty,
                       time,
                       uuid,
                       random,
                       mtl,
                       cookie
